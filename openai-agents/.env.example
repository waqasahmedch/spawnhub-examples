# Copy this file to .env and fill in your values

# Required: OpenAI API key
OPENAI_API_KEY="sk-..."

# SpawnHub ingestion endpoint — use Docker stack URL (default shown)
# Local dev (make ingestion): http://localhost:8000
# Docker stack: http://ingest.localhost
SPAWNHUB_ENDPOINT=http://ingest.localhost

# SpawnHub API key — required when going through Kong (Docker stack)
# Find the dev key in infra/kong/kong.yml under consumers[].keyauth_credentials
# Not required when hitting localhost:8000 directly
SPAWNHUB_API_KEY=spwnhub_dev_key_replace_me
